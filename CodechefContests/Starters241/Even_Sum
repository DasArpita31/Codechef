#include <iostream>
using namespace std;

int main(){
    int T;
    cin>>T;

    while(T--){
        int N;
        cin>>N;
        int sum=0;
        int odd=0,even=0;

        for (int i=0;i<N;i++){
            int x;
            cin>>x;
            sum+=x;

            if (x%2==0)
                even++;
            else
                odd++;
        }

        if ((sum%2==0 && even>0)||(sum % 2 == 1 &&  odd>0))
            cout<<"Yes"<<endl;
        else
            cout << "No"<<endl;
    }

    return 0;
}
